{
  "compilerOptions": {
    "target": "ES2020",
    // Required: the lazy named-export getters in package/rspack/index.ts rely on
    // TypeScript's CommonJS emit initializing each named export to a configurable
    // `void 0` placeholder that Object.defineProperty then replaces. A different
    // module target could emit non-configurable bindings and break load. See the
    // comment block in that file and TODO(#641).
    "module": "commonjs",
    "lib": ["ES2020"],
    "importHelpers": false,
    "typeRoots": [
      "./node_modules/@types",
      "node_modules/@types",
      "../node_modules/@types"
    ],
    "declaration": true,
    "declarationMap": true,
    "outDir": "./package",
    "rootDir": "./package",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "moduleResolution": "node",
    "allowJs": true,
    "checkJs": false,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "strictFunctionTypes": true,
    "strictBindCallApply": true,
    "strictPropertyInitialization": false,
    "noImplicitThis": true,
    "alwaysStrict": true,
    "allowSyntheticDefaultImports": true,
    "preserveConstEnums": true,
    "isolatedModules": true,
    "removeComments": false
  },
  "include": ["package/**/*.ts"],
  "exclude": ["node_modules", "package/**/*.test.ts", "package/**/*.spec.ts"]
}
